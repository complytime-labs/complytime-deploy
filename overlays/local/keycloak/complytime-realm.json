{
  "realm": "complytime",
  "enabled": true,
  "sslRequired": "external",
  "accessTokenLifespan": 60,
  "clients": [
    {
      "clientId": "beacon-test",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "beacon-test-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "protocolMappers": [
        {
          "name": "hardcoded-audience-account",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "account",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "lightweight.claim": "false",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "beacon-test-wrong-aud",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "wrong-aud-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "defaultClientScopes": [],
      "optionalClientScopes": []
    },
    {
      "clientId": "beacon-test-short-lived",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "short-lived-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "attributes": {
        "access.token.lifespan": "5"
      },
      "protocolMappers": [
        {
          "name": "hardcoded-audience-account",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "account",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "lightweight.claim": "false",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "grafana-test",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "grafana-test-secret",
      "serviceAccountsEnabled": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "https://grafana.apps-crc.testing/login/generic_oauth",
        "https://localhost:3000/login/generic_oauth",
        "http://localhost:3000/login/generic_oauth"
      ],
      "attributes": {
        "post.logout.redirect.uris": "https://grafana.apps-crc.testing##https://localhost:3000##http://localhost:3000"
      },
      "webOrigins": [
        "https://grafana.apps-crc.testing",
        "https://localhost:3000"
      ]
    }
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "email": "testuser@example.com",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "testpass",
          "temporary": false
        }
      ]
    }
  ]
}
